<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <title><%= content_for?(:title) ? yield(:title) : "Distrito Médico" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="index, follow">
    <style>
      :root {
        --text: #1f2937;
        --muted: #6b7280;
        --link: #2563eb;
        --bg: #ffffff;
        --border: #e5e7eb;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: var(--bg); }
      body {
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, sans-serif;
        line-height: 1.6;
        font-size: 16px;
      }
      .container {
        max-width: 720px;
        margin: 0 auto;
        padding: 48px 24px 96px;
      }
      header { border-bottom: 1px solid var(--border); padding-bottom: 16px; margin-bottom: 32px; }
      header .brand { font-weight: 600; font-size: 18px; }
      header .updated { color: var(--muted); font-size: 14px; }
      h1 { font-size: 28px; margin: 0 0 8px; }
      h2 { font-size: 20px; margin: 32px 0 8px; }
      p, ul { margin: 0 0 12px; }
      ul { padding-left: 20px; }
      a { color: var(--link); text-decoration: none; }
      a:hover { text-decoration: underline; }
      footer { margin-top: 48px; padding-top: 16px; border-top: 1px solid var(--border); color: var(--muted); font-size: 14px; }
      footer a { color: var(--muted); }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <div class="brand">Distrito Médico</div>
      </header>

      <main>
        <%= yield %>
      </main>

      <footer>
        <%= link_to "Suporte", support_path %> &middot;
        <%= link_to "Política de Privacidade", privacy_policy_path %>
      </footer>
    </div>
  </body>
</html>
